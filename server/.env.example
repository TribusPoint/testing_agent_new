# App
APP_ENV=development
DEBUG=true

# Database — use your local Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/testing_agent
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/testing_agent

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# LLM routing — set provider to "openai" or "anthropic"
LLM_PROVIDER=openai
GENERATION_MODEL=gpt-4o
EVALUATION_MODEL=gpt-4o
UTTERANCE_MODEL=gpt-4o-mini

# Conversation engine
SF_TURN_TIMEOUT=30
SF_MAX_RETRIES=3
SF_RETRY_DELAY=1.0
MAX_CONV_CHARS=8000
MAX_FOLLOW_UPS=5

# Security
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
MASTER_API_KEY=your-master-api-key-here
