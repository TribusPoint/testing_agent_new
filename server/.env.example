# App
APP_ENV=development
DEBUG=true

# Database — Railway provides these automatically if you add a Postgres plugin
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/testing_agent
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/testing_agent

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# LLM routing — openai | anthropic | gemini (PATCH /api/config from console switches provider + default models)
LLM_PROVIDER=openai
GENERATION_MODEL=gpt-4o
EVALUATION_MODEL=gpt-4o
UTTERANCE_MODEL=gpt-4o-mini

# Conversation engine
SF_TURN_TIMEOUT=30
SF_MAX_RETRIES=3
SF_RETRY_DELAY=1.0
MAX_CONV_CHARS=8000
MAX_FOLLOW_UPS=5

# Security
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
MASTER_API_KEY=your-master-api-key-here
# Admin-only: resetting another user’s password (PATCH …/users/{id}/password) and approving a pending forgot-password request (POST …/password-resets/{id}/approve). End users never enter this on the change-password screen.
ADMIN_PASSWORD_SECRET_CODE=TribusPoint

# CORS — comma-separated origins (only needed for local dev or if frontend is on a different domain)
# In the unified Railway deployment, the frontend proxies to the backend so CORS isn't needed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
